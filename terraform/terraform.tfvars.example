# Copy this file to terraform.tfvars and populate real values.
# terraform.tfvars is in .gitignore — NEVER commit it.

aws_region  = "us-east-1"
environment = "prod"

# Networking
vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["us-east-1a", "us-east-1b", "us-east-1c"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24", "10.0.13.0/24"]

# Storage
frontend_bucket_name   = "much-to-do-frontend-prod-<your-account-id>"
cloudfront_price_class = "PriceClass_100"

# Compute
instance_type        = "t3.small"
ami_id               = "ami-0c02fb55956c7d316"   # Amazon Linux 2023, us-east-1 – check for latest
key_name             = "much-to-do-keypair"
asg_min_size         = 1
asg_max_size         = 4
asg_desired_capacity = 2

# Secrets Manager secret ID containing the MongoDB Atlas URI
# Create it first: aws secretsmanager create-secret --name much-to-do/mongo-uri ...
mongo_uri_secret_id = "much-to-do/mongo-uri"

# Monitoring
alarm_email = "ops@example.com"
