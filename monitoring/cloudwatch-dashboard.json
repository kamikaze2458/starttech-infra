{
  "widgets": [
    {
      "type": "metric",
      "x": 0, "y": 0, "width": 12, "height": 6,
      "properties": {
        "title": "Backend – CPU Utilisation (ASG)",
        "metrics": [
          ["AWS/EC2", "CPUUtilization", "AutoScalingGroupName", "${asg_name}",
           {"stat": "Average", "period": 60, "label": "Avg CPU %"}]
        ],
        "view": "timeSeries",
        "region": "${region}",
        "yAxis": { "left": { "min": 0, "max": 100 } }
      }
    },
    {
      "type": "metric",
      "x": 12, "y": 0, "width": 12, "height": 6,
      "properties": {
        "title": "ALB – Requests & HTTP 5xx Errors",
        "metrics": [
          ["AWS/ApplicationELB", "RequestCount",              "LoadBalancer", "${alb_arn_suffix}", {"stat": "Sum",  "period": 60, "label": "Requests"}],
          ["AWS/ApplicationELB", "HTTPCode_Target_5XX_Count", "LoadBalancer", "${alb_arn_suffix}", {"stat": "Sum",  "period": 60, "label": "5xx Errors"}],
          ["AWS/ApplicationELB", "HTTPCode_Target_4XX_Count", "LoadBalancer", "${alb_arn_suffix}", {"stat": "Sum",  "period": 60, "label": "4xx Errors"}]
        ],
        "view": "timeSeries",
        "region": "${region}"
      }
    },
    {
      "type": "metric",
      "x": 0, "y": 6, "width": 12, "height": 6,
      "properties": {
        "title": "ALB – Target Response Time (p50 / p99)",
        "metrics": [
          ["AWS/ApplicationELB", "TargetResponseTime", "LoadBalancer", "${alb_arn_suffix}", {"stat": "p50", "period": 60, "label": "p50 (s)"}],
          ["AWS/ApplicationELB", "TargetResponseTime", "LoadBalancer", "${alb_arn_suffix}", {"stat": "p99", "period": 60, "label": "p99 (s)"}]
        ],
        "view": "timeSeries",
        "region": "${region}"
      }
    },
    {
      "type": "metric",
      "x": 12, "y": 6, "width": 12, "height": 6,
      "properties": {
        "title": "ElastiCache Redis – CPU & Connections",
        "metrics": [
          ["AWS/ElastiCache", "EngineCPUUtilization", "ReplicationGroupId", "${redis_group_id}", {"stat": "Average", "period": 60}],
          ["AWS/ElastiCache", "CurrConnections",      "ReplicationGroupId", "${redis_group_id}", {"stat": "Average", "period": 60}]
        ],
        "view": "timeSeries",
        "region": "${region}"
      }
    },
    {
      "type": "log",
      "x": 0, "y": 12, "width": 24, "height": 6,
      "properties": {
        "title": "Application ERROR Logs (last 1 h)",
        "query": "SOURCE '/much-to-do/${environment}/app' | fields @timestamp, @message | filter @message like /ERROR|FATAL|panic/ | sort @timestamp desc | limit 100",
        "region": "${region}",
        "view": "table"
      }
    },
    {
      "type": "metric",
      "x": 0, "y": 18, "width": 12, "height": 6,
      "properties": {
        "title": "Deployments",
        "metrics": [
          ["MuchToDo/Deployments", "DeploymentCount", "Environment", "production", "Service", "backend",
           {"stat": "Sum", "period": 3600, "label": "Backend deploys/hr"}]
        ],
        "view": "timeSeries",
        "region": "${region}"
      }
    }
  ]
}
